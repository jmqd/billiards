# Slight cut to the right side pocket, about five degrees off the straight-in line from center,
# with a little draw on the cue ball.
ball cue at center
ball one at (2.8, 4.05)
cue_strike(default).mass_ratio(1.0).energy_loss(0.1)
shot(cue).heading(84.2deg).speed(32ips).tip(side: 0.0R, height: -0.3R).using(default)
